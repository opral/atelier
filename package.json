{
	"name": "@opral/atelier",
	"version": "0.7.3",
	"type": "module",
	"main": "./dist/atelier.js",
	"module": "./dist/atelier.js",
	"types": "./dist/types/index.d.ts",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/atelier.js",
			"default": "./dist/atelier.js"
		},
		"./state-adapters": {
			"types": "./dist/types/state-adapters.d.ts",
			"import": "./dist/state-adapters.js",
			"default": "./dist/state-adapters.js"
		},
		"./style.css": "./dist/atelier.css",
		"./package.json": "./package.json"
	},
	"packageManager": "pnpm@10.13.1",
	"scripts": {
		"dev": "pnpm --dir preview/web dev",
		"build": "vite build && tsc -p tsconfig.build.json && node scripts/prune-types.mjs",
		"build:preview": "pnpm --dir preview/web build && node scripts/compress-preview-wasm.mjs",
		"deploy:preview": "wrangler versions upload",
		"typecheck": "tsc -p . --pretty false",
		"format": "oxfmt --write .",
		"format:check": "oxfmt --check .",
		"lint": "oxlint --tsconfig ./tsconfig.json --ignore-path .gitignore --format stylish .",
		"lint:fix": "oxlint --tsconfig ./tsconfig.json --ignore-path .gitignore --fix .",
		"test": "vitest run",
		"test:consumer": "pnpm run build && pnpm --dir fixtures/consumer build",
		"ci": "pnpm run build && pnpm test && pnpm --dir fixtures/consumer build"
	},
	"peerDependencies": {
		"@lix-js/sdk": "^0.8.2",
		"react": "^19.2.0",
		"react-dom": "^19.2.0"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"@codemirror/commands": "^6.10.4",
		"@codemirror/lang-css": "^6.3.1",
		"@codemirror/lang-javascript": "^6.2.5",
		"@codemirror/lang-json": "^6.0.2",
		"@codemirror/lang-python": "^6.2.1",
		"@codemirror/language": "^6.12.4",
		"@codemirror/search": "^6.7.1",
		"@codemirror/state": "^6.7.1",
		"@codemirror/view": "^6.43.6",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@glideapps/glide-data-grid": "^6.0.3",
		"@lezer/highlight": "^1.2.3",
		"@lix-js/html-diff": "^0.1.0",
		"@pierre/trees": "1.0.0-beta.5",
		"@radix-ui/react-dropdown-menu": "^2.1.20",
		"@radix-ui/react-tooltip": "^1.2.12",
		"@tiptap/core": "^3.27.3",
		"@tiptap/extension-history": "^3.27.3",
		"@tiptap/extension-placeholder": "^3.27.3",
		"@tiptap/pm": "^3.27.3",
		"@tiptap/react": "^3.27.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"kysely": "^0.29.3",
		"lodash": "^4.18.1",
		"lucide-react": "^1.24.0",
		"mdast-util-from-markdown": "^2.0.3",
		"mdast-util-frontmatter": "^2.0.1",
		"mdast-util-gfm": "^3.1.0",
		"mdast-util-to-markdown": "^2.1.2",
		"mermaid": "^11.16.0",
		"micromark-extension-frontmatter": "^2.0.0",
		"micromark-extension-gfm": "^3.0.0",
		"papaparse": "^5.5.4",
		"pdfjs-dist": "5.4.624",
		"react-resizable-panels": "^4.12.1",
		"tailwind-merge": "^3.6.0",
		"use-sync-external-store": "^1.6.0",
		"yaml": "^2.8.2"
	},
	"devDependencies": {
		"@lix-js/sdk": "^0.8.2",
		"@tailwindcss/vite": "^4.3.2",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^24.10.2",
		"@types/papaparse": "^5.5.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.2",
		"@types/seedrandom": "^3.0.8",
		"@vitejs/plugin-react": "^6.0.3",
		"babel-plugin-react-compiler": "^1.0.0",
		"happy-dom": "^20.10.6",
		"jsdom": "^29.1.1",
		"oxfmt": "^0.58.0",
		"oxlint": "^1.73.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"seedrandom": "^3.0.5",
		"tailwindcss": "^4.3.2",
		"tw-animate-css": "^1.3.7",
		"typescript": "^7.0.2",
		"vite": "^8.1.4",
		"vitest": "^4.1.10",
		"wrangler": "^4.110.0"
	}
}
