{
	"name": "@opral/atelier",
	"private": true,
	"version": "0.7.3",
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"packageManager": "pnpm@10.13.1",
	"pnpm": {
		"peerDependencyRules": {
			"allowedVersions": {
				"@glideapps/glide-data-grid>react": "^19.0.0",
				"@glideapps/glide-data-grid>react-dom": "^19.0.0"
			}
		}
	},
	"scripts": {
		"dev": "pnpm run dev:preview:electron",
		"dev:preview:electron": "pnpm run build:preview:electron-process && concurrently -k \"pnpm run dev:preview:renderer\" \"wait-on tcp:4174 && ATELIER_PREVIEW_URL=http://127.0.0.1:4174 env -u ELECTRON_RUN_AS_NODE electron --remote-debugging-port=9229 .preview/electron/main.mjs\"",
		"dev:preview:renderer": "vite --config preview/electron/vite.config.ts --host 127.0.0.1 --port 4174 --strictPort",
		"predev": "pnpm run build:lix",
		"build:preview:electron-process": "tsc -p preview/electron/tsconfig.json",
		"build:preview:renderer": "vite build --config preview/electron/vite.config.ts",
		"build": "vite build",
		"prebuild": "pnpm run build:lix",
		"build:lix": "node scripts/build-lix.mjs",
		"typecheck": "tsc -p . --pretty false",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "oxlint --tsconfig ./tsconfig.json --ignore-path .gitignore --ignore-pattern \"submodule/**\" --format stylish .",
		"lint:fix": "oxlint --tsconfig ./tsconfig.json --ignore-path .gitignore --ignore-pattern \"submodule/**\" --fix .",
		"test": "vitest run",
		"ci": "pnpm run build && pnpm test"
	},
	"dependencies": {
		"@base-ui-components/react": "1.0.0-beta.4",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@glideapps/glide-data-grid": "^6.0.3",
		"@lix-js/html-diff": "^0.1.0",
		"@lix-js/sdk": "workspace:*",
		"@pierre/trees": "1.0.0-beta.4",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@tiptap/core": "^3.3.0",
		"@tiptap/extension-history": "^3.4.4",
		"@tiptap/extension-placeholder": "^3.4.4",
		"@tiptap/pm": "^3.3.0",
		"@tiptap/react": "^3.0.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"kysely": "^0.28.7",
		"lodash": "^4.18.1",
		"lucide-react": "^0.542.0",
		"marked": "^4.3.0",
		"mdast-util-from-markdown": "^2.0.3",
		"mdast-util-frontmatter": "^2.0.1",
		"mdast-util-gfm": "^3.1.0",
		"mdast-util-to-markdown": "^2.1.2",
		"mermaid": "^11.16.0",
		"micromark-extension-frontmatter": "^2.0.0",
		"micromark-extension-gfm": "^3.0.0",
		"papaparse": "^5.5.3",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-resizable-panels": "^2.1.9",
		"tailwind-merge": "^3.3.1"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.0.0",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.0.0",
		"@types/node": "^24.10.2",
		"@types/papaparse": "^5.5.2",
		"@types/react": "^19.2.2",
		"@types/react-dom": "^19.2.2",
		"@types/seedrandom": "^3.0.8",
		"@vitejs/plugin-react": "^5.0.2",
		"babel-plugin-react-compiler": "^1.0.0",
		"concurrently": "^9.2.1",
		"electron": "^40.6.1",
		"happy-dom": "^18.0.1",
		"oxlint": "^1.23.0",
		"prettier": "^3.6.2",
		"seedrandom": "^3.0.5",
		"tailwindcss": "^4.0.0",
		"tw-animate-css": "^1.3.7",
		"typescript": "^5.9.2",
		"vite": "^7.1.3",
		"vitest": "^4.0.3",
		"wait-on": "^9.0.4"
	}
}
