{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"moduleDetection": "force",
		"verbatimModuleSyntax": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"]
		},
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"strict": true,
		"jsx": "react-jsx",
		"types": ["vite/client", "node"]
	},
	"include": [
		"src",
		"setup-tests.ts",
		"preview/electron/lix-client.ts",
		"preview/electron/renderer.ts",
		"preview/electron/renderer-types.d.ts"
	]
}
