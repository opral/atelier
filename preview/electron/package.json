{
	"name": "@opral/atelier-electron-preview",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"predev": "pnpm --dir ../.. build:lix && pnpm --dir ../.. build",
		"dev": "pnpm run build:process && concurrently -k \"pnpm run dev:renderer\" \"wait-on tcp:4174 && ATELIER_PREVIEW_URL=http://127.0.0.1:4174 env -u ELECTRON_RUN_AS_NODE electron --remote-debugging-port=9229 ../../.preview/electron/main.mjs\"",
		"dev:renderer": "vite --config vite.config.ts --host 127.0.0.1 --port 4174 --strictPort",
		"prebuild": "pnpm --dir ../.. build:lix && pnpm --dir ../.. build",
		"build": "pnpm run build:process && pnpm run build:renderer",
		"build:process": "tsc -p tsconfig.process.json",
		"build:renderer": "vite build --config vite.config.ts",
		"typecheck": "tsc -p tsconfig.json --pretty false"
	},
	"dependencies": {
		"@lix-js/sdk": "workspace:*",
		"@opral/atelier": "workspace:*"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.0.0",
		"@types/node": "^24.10.2",
		"@vitejs/plugin-react": "^5.0.2",
		"concurrently": "^9.2.1",
		"electron": "^40.6.1",
		"typescript": "^5.9.2",
		"vite": "^7.1.3",
		"wait-on": "^9.0.4"
	}
}
